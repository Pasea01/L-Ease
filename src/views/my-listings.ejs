<!DOCTYPE html>
<html lang="en">

<%- include("partials/head") %>

<body>

<%- include("partials/navbar") %>

<main class="dashboard">

    <section class="dashboard-header">

        <div>
            <h1>My Listings</h1>
            <p>Manage all the assets you've listed on L-ease.</p>
        </div>

        <a href="/listings/new" class="primary-btn">
            + New Listing
        </a>

    </section>

    <% if (listings.length === 0) { %>

        <div class="activity-card">

            <h2>No Listings Yet</h2>

            <p>
                You haven't listed any assets yet.
            </p>

            <br>

            <a href="/listings/new" class="primary-btn">
                Create Your First Listing
            </a>

        </div>

    <% } else { %>

        <div class="listing-grid">

            <% listings.forEach(listing => { %>

            <div class="listing-card">

                <% if (listing.image_url) { %>

                    <img
                        src="/uploads/<%= listing.image_url %>"
                        class="listing-image"
                        alt="<%= listing.title %>"
                    >

                <% } else { %>

                    <img
                        src="<%= getCategoryImage(listing.category) %>"
                        class="listing-image"
                        alt="<%= listing.category %>"
                    >

                <% } %>

                <div class="listing-content">

                    <h3><%= listing.title %></h3>

                    <div class="listing-meta">

                        <span class="category-badge">

                            <% if(listing.category==="Property"){ %>🏠<% } %>
                            <% if(listing.category==="Vehicle"){ %>🚗<% } %>
                            <% if(listing.category==="Electronics"){ %>💻<% } %>
                            <% if(listing.category==="Furniture"){ %>🪑<% } %>
                            <% if(listing.category==="Tools"){ %>🔧<% } %>
                            <% if(listing.category==="Equipment"){ %>⚙️<% } %>
                            <% if(listing.category==="Livestock"){ %>🐄<% } %>
                            <% if(listing.category==="Other"){ %>📦<% } %>

                            <%= listing.category %>

                        </span>

                        <span class="listing-location">

                            📍 <%= listing.location %>

                        </span>

                    </div>

                    <div class="listing-price">

                        KES <%= listing.price_per_day %> / day

                    </div>

                    <p class="listing-description">

                        <%= listing.description %>

                    </p>

                    <div class="listing-buttons">

                        <a
                            href="/listings/edit/<%= listing.id %>"
                            class="primary-btn"
                        >
                            Edit
                        </a>

                        <a
                            href="/listings/delete/<%= listing.id %>"
                            class="secondary-btn"
                            onclick="return confirm('Delete this listing?')"
                        >
                            Delete
                        </a>

                    </div>

                </div>

            </div>

            <% }) %>

                    </div>

                <% } %>

</main>

<%- include("partials/footer") %>

<%- include("partials/scripts") %>

</body>

</html>