<% if (flash) { %>
<div class="flash flash-<%= flash.type %>">
    <%= flash.message %>
</div>
<% } %>

<nav class="navbar">

    <!-- Left -->
    <div class="navbar-left">

        <a href="/" class="logo">

            <img
                src="/images/logo.png"
                alt="L-Ease"
                class="logo-image"
            >

        </a>

    </div>

    <!-- Center -->
    <div class="navbar-center">

        <ul class="nav-links">

            <li>
                <a href="/listings">
                    Browse Assets
                </a>
            </li>

            <li>
                <a href="#">
                    Categories
                </a>
            </li>

            <li>
                <a href="#">
                    About
                </a>
            </li>

        </ul>

    </div>

    <!-- Right -->
    <div class="navbar-right">

        <% if(user){ %>

        <div class="user-menu">

            <button class="user-btn" id="userMenuBtn">

                <div class="avatar">

                    <%= user.full_name.charAt(0).toUpperCase() %>

                </div>

                <span class="username">

                    <%= user.full_name.split(" ")[0] %>

                </span>

                <span class="caret">

                    ▼

                </span>

            </button>

            <div class="dropdown-menu" id="dropdownMenu">

                <div class="dropdown-header">

                    <strong>

                        <%= user.full_name %>

                    </strong>

                    <small>

                        <%= user.email %>

                    </small>

                </div>

                <hr>

                <a href="/dashboard">🏠 Dashboard</a>

                <a href="/profile">👤 Profile</a>

                <a href="/listings/my-listings">📦 My Listings</a>

                <a href="/leases/my-requests">📝 My Requests</a>

                <a href="/leases/owner">📑 Incoming Requests</a>

                <a href="/messages">💬 Messages</a>

                <hr>

                <a href="/auth/logout">

                    🚪 Logout

                </a>

            </div>

        </div>

        <% } else { %>

        <div class="guest-buttons">

            <a href="/login" class="secondary-btn">

                Login

            </a>

            <a href="/register" class="primary-btn">

                Sign Up

            </a>

        </div>

        <% } %>

    </div>

</nav>