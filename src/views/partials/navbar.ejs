
<% if (flash) { %>

    <div class="flash flash-<%= flash.type %>">

        <%= flash.message %>

    </div>

<% } %>

<nav class="navbar">

    <div class="logo">
        <a href="/">L-Ease</a>
    </div>

    <ul class="nav-links">

        <li><a href="/">Home</a></li>

        <li><a href="/listings">Browse</a></li>

        <li><a href="#">Categories</a></li>

        <li><a href="#">About</a></li>

    </ul>

    <% if(user){ %>

        <div class="user-menu">

            <button class="user-btn" id="userMenuBtn">

                👤 <%= user.full_name %> ▼

            </button>

            <div class="dropdown-menu" id="dropdownMenu">

                <a href="/dashboard">🏠 Dashboard</a>

                <a href="/listings/my-listings">📦 My Listings</a>

                <a href="/leases/my-requests">📝 My Lease Requests</a>

                <a href="/leases/owner">📑 Incoming Lease Requests</a>

                <a href="/messages">💬 Inbox</a>

                <hr>

                <a href="/auth/logout">🚪 Logout</a>

            </div>

        </div>

        <% } else { %>

        <div class="nav-buttons">

            <a href="/login" class="secondary-btn">Login</a>

            <a href="/register" class="primary-btn">Sign Up</a>

        </div>

    <% } %>

</nav>