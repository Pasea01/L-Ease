<!DOCTYPE html>
<html lang="en">

<%- include("partials/head") %>

<body>

<%- include("partials/navbar") %>

<main class="auth-container">

    <h1>Edit Listing</h1>

    <form action="/listings/edit/<%= listing.id %>"
        method="POST"
        enctype="multipart/form-data"
        >

        <h3>Current Image</h3>

            <% if (listing.image_url) { %>

                <img
                    src="/uploads/<%= listing.image_url %>"
                    class="listing-image-large"
                    alt="<%= listing.title %>"
                >

            <% } else { %>

                <img
                    src="<%= getCategoryImage(listing.category) %>"
                    class="listing-image-large"
                    alt="<%= listing.category %>"
                >

            <% } %>

        <br><br>

        <input
            type="text"
            name="title"
            value="<%= listing.title %>"
            required
        >

        <textarea
            name="description"
            rows="5"
            required
        ><%= listing.description %></textarea>

        <input
            type="text"
            name="category"
            value="<%= listing.category %>"
            required
        >

        <input
            type="number"
            name="price_per_day"
            value="<%= listing.price_per_day %>"
            required
        >

        <input
            type="text"
            name="location"
            value="<%= listing.location %>"
            required
        >

        <label><strong>Replace Image (optional)</strong></label>

        <input
            type="file"
            name="image"
            accept="image/*"
        >

        <p style="color:#6b7280;font-size:14px;">
            Leave empty to keep the current image.
        </p>

        <button type="submit" class="primary-btn">
            Save Changes
        </button>

    </form>

</main>

<%- include("partials/footer") %>

<%- include("partials/scripts") %>

</body>
</html>