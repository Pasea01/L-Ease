<!DOCTYPE html>
<html lang="en">

<%- include("partials/head") %>

<body>

<%- include("partials/navbar") %>

<main class="auth-container">

    <h1>Create Your L-ease Account</h1>

    <form action="/auth/register" method="POST">

        <input
            type="text"
            name="full_name"
            placeholder="Full Name"
            required
        >

        <input
            type="email"
            name="email"
            placeholder="Email Address"
            required
        >

        <input
            type="text"
            name="phone"
            placeholder="Phone Number"
        >

        <input
            type="password"
            name="password"
            placeholder="Password"
            required
        >

        <button type="submit">

            Create Account

        </button>

    </form>

</main>

<%- include("partials/footer") %>

<%- include("partials/scripts") %>

</body>

</html>