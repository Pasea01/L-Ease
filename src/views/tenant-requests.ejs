<!DOCTYPE html>

<html lang="en">

<%- include("partials/head") %>

<body>

<%- include("partials/navbar") %>

<main class="dashboard">

    <div class="dashboard-header">

        <div>

            <h1>My Lease Requests</h1>

            <p>

                Track every lease request you've submitted.

            </p>

        </div>

    </div>

    <% if(requests.length === 0){ %>

        <div class="activity-card">

            <h2>No Requests Yet</h2>

            <p>

                You haven't requested any leases yet.

            </p>

        </div>

    <% } else { %>

        <div class="listing-grid">

            <% requests.forEach(request => { %>

                <div class="listing-card">

                   <% if (request.image_url) { %>

                        <img
                            src="/uploads/<%= request.image_url %>"
                            class="listing-image"
                            alt="<%= request.title %>"
                            onerror="this.onerror=null; this.src='/images/categories/<%= (request.category || 'other').toLowerCase() %>.png';"
                        >

                    <% } else { %>

                        <img
                            src="/images/categories/<%= (request.category || 'other').toLowerCase() %>.png"
                            class="listing-image"
                            alt="<%= request.category %>"
                        >

                    <% } %>

                <div class="listing-content">

                    <h3><%= request.title %></h3>

                    <p>

                        <strong>Owner:</strong>

                        <%= request.owner_name %>

                    </p>

                    <p>

                        <strong>From:</strong>

                        <%= request.start_date %>

                    </p>

                    <p>

                        <strong>To:</strong>

                        <%= request.end_date %>

                    </p>

                    <p>

                        <strong>Status:</strong>

                        <%= request.status %>

                    </p>

                    <br>

                    <% if(request.status === "approved"){ %>

                        <a
                            href="/messages/<%= request.asset_id %>/<%= request.owner_id %>"
                            class="primary-btn"
                        >

                            Open Chat

                        </a>

                    <% } else if(request.status === "pending"){ %>

                        <button
                            class="secondary-btn"
                            disabled
                        >

                            Awaiting Approval

                        </button>

                    <% } else { %>

                        <button
                            class="danger-btn"
                            disabled
                        >

                            Rejected

                        </button>

                    <% } %>

                </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</main>

<%- include("partials/footer") %>

<%- include("partials/scripts") %>

</body>

</html>