<!DOCTYPE html>
<html lang="en">

<%- include("partials/head") %>

<body>

<%- include("partials/navbar") %>

<main class="dashboard">

    <div class="dashboard-header">

        <div>

            <h1>Inbox</h1>

            <p>Continue conversations with owners and tenants.</p>

        </div>

    </div>

    <% if (conversations.length === 0) { %>

        <div class="activity-card">

            <h2>No conversations yet</h2>

            <p>Your conversations will appear here after a lease is approved.</p>

        </div>

    <% } else { %>

        <div class="conversation-list">

            <% conversations.forEach(conversation => { %>

                <a
                    href="/messages/<%= conversation.asset_id %>/<%= conversation.other_user_id %>"
                    class="conversation-card"
                >

                    <% if(conversation.image_url){ %>

                        <img
                            src="/uploads/<%= conversation.image_url %>"
                            class="conversation-image"
                            onerror="this.onerror=null;this.src='/images/categories/<%= (conversation.category || 'other').toLowerCase() %>.png';"
                        >

                    <% } else { %>

                        <img
                            src="/images/categories/<%= (conversation.category || 'other').toLowerCase() %>.png"
                            class="conversation-image"
                        >

                    <% } %>

                    <div class="conversation-details">

                        <h3><%= conversation.title %></h3>

                        <p class="conversation-user">

                            <strong><%= conversation.other_user %></strong>

                        </p>

                        <p class="conversation-preview">

                            <%= conversation.last_message %>

                        </p>

                    </div>

                    <div class="conversation-time">

                        <small>

                            <%= conversation.last_time %>

                        </small>

                    </div>

                </a>

            <% }) %>

        </div>

    <% } %>

</main>

<%- include("partials/footer") %>

<%- include("partials/scripts") %>

</body>

</html>