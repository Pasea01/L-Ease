<!DOCTYPE html>
<html lang="en">

<%- include("partials/head") %>

<body>

<%- include("partials/navbar") %>

<main class="dashboard">

    <div class="dashboard-header">

        <div>

        <h1>Explore</h1>

            <p>
                Discover assets available for lease from trusted owners.
            </p>

        </div>

    </div>
    <!-- Search Bar -->

    <section class="search-section">

        <form
            class="search-box"
            action="/listings"
            method="GET"
        >

            <input
                type="text"
                name="search"
                placeholder="Search assets..."
                value="<%= search || '' %>"
            >

            <select name="category">

                <option value="">All Categories</option>

                <option value="Property"
                    <%= category === "Property" ? "selected" : "" %>>
                    Property
                </option>

                <option value="Vehicle"
                    <%= category === "Vehicle" ? "selected" : "" %>>
                    Vehicle
                </option>

                <option value="Electronics"
                    <%= category === "Electronics" ? "selected" : "" %>>
                    Electronics
                </option>

                <option value="Furniture"
                    <%= category === "Furniture" ? "selected" : "" %>>
                    Furniture
                </option>

                <option value="Tools"
                    <%= category === "Tools" ? "selected" : "" %>>
                    Tools
                </option>

                <option value="Equipment"
                    <%= category === "Equipment" ? "selected" : "" %>>
                    Equipment
                </option>

                <option value="Livestock"
                    <%= category === "Livestock" ? "selected" : "" %>>
                    Livestock
                </option>

                <option value="Other"
                    <%= category === "Other" ? "selected" : "" %>>
                    Other
                </option>

            </select>

            <button
                type="submit"
                class="primary-btn"
            >

                Search

            </button>

        </form>

    </section>

    <!-- Listings -->

    <% if (listings.length === 0) { %>

        <div class="listing-card">

            <h2>No listings available.</h2>

            <p>Be the first to list an asset!</p>

        </div>

    <% } else { %>

        <div class="listing-grid">

            <% listings.forEach(listing => { %>

                <div class="listing-card">

                    <% if (listing.image_url) { %>

                    <img
                        src="/uploads/<%= listing.image_url %>"
                        class="listing-image"
                    >

                <% } else { %>

                    <img
                        src="<%= getCategoryImage(listing.category) %>"
                        class="listing-image"
                        alt="<%= listing.category %>"
                    >

                <% } %>

                    <h3><%= listing.title %></h3>

                    <p>

                        <strong>Category:</strong>

                        <%= listing.category %>

                    </p>

                    <p>

                        <strong>Location:</strong>

                        <%= listing.location %>

                    </p>

                    <p>

                        <strong>Owner:</strong>

                        <%= listing.full_name %>

                    </p>

                    <strong>

                        KES <%= listing.price_per_day %> / day

                    </strong>

                    <br><br>

                    <a
                        href="/listings/<%= listing.id %>"
                        class="primary-btn"
                    >

                        View Details

                    </a>

                </div>

            <% }) %>

        </div>

    <% } %>

</main>

<%- include("partials/footer") %>

<%- include("partials/scripts") %>

</body>

</html>